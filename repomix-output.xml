                expect(component.isDropdownOpen()).toBe(true);
                component.toggleDropdown();
                expect(component.isDropdownOpen()).toBe(false);
            });
        });

        describe('closeDropdown', () => {
            it('deve fechar dropdown quando closeDropdown() chamado', () => {

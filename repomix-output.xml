  border: none;
  color: inherit;
  cursor: pointer;
  font-size: 18px;
  padding: 0;
}

.alert__content {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.alert__icon {
  background: rgba(255, 255, 255, 0.7);
  border-radius: 50%;

@use '../../colors.scss' as *;

$text-main: #344054;
$text-muted: #667085;
$text-disabled: #98a2b3;

$border-color: #d0d5dd;
$bg-surface: #ffffff;
$bg-hover: #f9fafb;

$radius-sm: 8px;
$radius-md: 12px;

$shadow-sm: 0 1px 2px rgba(16, 24, 40, 0.05);
$shadow-lg: 0 12px 16px -4px rgba(16, 24, 40, 0.08), 0 4px 6px -2px rgba(16, 24, 40, 0.03);

@mixin focus-ring($color: $color-primary, $size: 3px) {
    outline: none;
    box-shadow: 0 0 0 $size rgba($color, 0.15);
}

@mixin button-reset {
    border: none;
    background: transparent;
    cursor: pointer;
    font-family: inherit;
}

@mixin smooth-transition {
    transition: background-color .2s ease,
        border-color .2s ease,
        box-shadow .2s ease,
        color .2s ease;
}

.date-picker-wrapper {
    position: relative;
    font-family: system-ui, -apple-system, sans-serif;
    text-align: left;
    min-width: 160px;
    width: 100%;
}

.trigger-btn {
    @include button-reset;
    @include smooth-transition;

    width: 100%;
    display: flex;
    align-items: center;
    padding: 10px 14px;

    background: $bg-surface;
    border: 1px solid $border-color;
    border-radius: $radius-sm;
    box-shadow: $shadow-sm;
    font-size: 14px;
    color: $text-main;

    &:hover {
        background: $bg-hover;
    }

    &:focus {
        border-color: $color-primary;
        @include focus-ring;
    }

    .icon {
        width: 20px;
        height: 20px;
        margin-right: 8px;
        color: $text-muted;
    }

    .placeholder {
        color: $text-muted;
    }
}

.calendar-popover {

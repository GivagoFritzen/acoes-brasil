<section class="proventos">
  <app-alerts [alerts]="alerts()" (dismissed)="handleAlertDismiss($event)"></app-alerts>

  <header class="proventos__header" data-tour="proventos-title">
    <h2>{{ 'proventos.title' | translate }}</h2>
    <app-simple-button (btnClick)="openCreateModal()">
      {{ 'proventos.addProvento' | translate }}
    </app-simple-button>
  </header>

  <div class="proventos__filters">
    <label>
      {{ 'proventos.code' | translate }}
      <app-simple-input [value]="filtroCodigo()" [maxLength]="7" (valueChange)="handleFilterCodeChange($event)" />
    </label>

    <label>
      {{ 'proventos.type' | translate }}
      <app-simple-select [value]="filtroTipo()" [options]="tipoOptions" [placeholder]="'proventos.all' | translate"
        (valueChange)="handleFilterTypeChange($event)">
      </app-simple-select>
    </label>

    <label>
      {{ 'proventos.startDate' | translate }}
      <app-date-picker [value]="filtroData()" (dateChange)="handleFilterStartChange($event)">
      </app-date-picker>
    </label>

    <label>
      {{ 'proventos.endDate' | translate }}
      <app-date-picker [value]="filtroDataFinal()" (dateChange)="handleFilterEndChange($event)">
      </app-date-picker>
    </label>

    <label>
      {{ 'proventos.group' | translate }}
      <app-simple-checkbox [checked]="juntarPorCodigo()" (checkedChange)="handleJuntarPorCodigoChange($event)">
      </app-simple-checkbox>
    </label>

    <div class="proventos__buttons">
      <app-simple-button (btnClick)="applyFilter()">
        {{ 'proventos.filter' | translate }}
      </app-simple-button>

      <app-simple-button variant="cancelar" (btnClick)="clearFilter()">
        {{ 'proventos.clear' | translate }}
      </app-simple-button>
    </div>
  </div>

  <div class="proventos__table">
    <div class="proventos__row proventos__row--head">
      <span>{{ 'proventos.code' | translate }}</span>
      <span>{{ 'proventos.type' | translate }}</span>
      <span>{{ 'proventos.institution' | translate }}</span>
      <span>{{ 'proventos.quantity' | translate }}</span>
      <span>{{ 'proventos.unitPrice' | translate }}</span>
      <span>{{ 'proventos.netValue' | translate }}</span>
      <span>{{ 'proventos.date' | translate }}</span>
      <span>{{ 'proventos.actions' | translate }}</span>
    </div>

    <div *ngIf="isLoading() && !errorMessage() && proventos().length === 0" class="proventos__row">
      <span>{{ 'proventos.loadingProventos' | translate }}</span>
    </div>

    <article class="proventos__row" *ngFor="let item of proventos(); trackBy: trackByProventoId">
      <span class="proventos__code" [attr.data-label]="'proventos.code' | translate">{{ item.codigo }}</span>
      <span [attr.data-label]="'proventos.type' | translate">{{ formatTipo(item.tipo) }}</span>
      <span [attr.data-label]="'proventos.institution' | translate">{{ item.instituicao }}</span>
      <span [attr.data-label]="'proventos.quantity' | translate">{{ item.quantidade }}</span>
      <span [attr.data-label]="'proventos.unitPrice' | translate">{{ item.precoUnitario | currency:'BRL' }}</span>
      <span [attr.data-label]="'proventos.netValue' | translate">{{ item.valorLiquido | currency:'BRL' }}</span>
      <span [attr.data-label]="'proventos.date' | translate">{{ formatDateForDisplay(item.data) }}</span>
      <span class="proventos__actions" [attr.data-label]="'proventos.actions' | translate">
        <app-action-button title="{{ 'proventos.deleteProventoTitle' | translate }}" (actionClick)="openDeleteModal(item)"></app-action-button>
      </span>
    </article>
  </div>

  <footer class="proventos__pagination">
    <app-pagination [page]="page()" [totalPages]="totalPages()" align="right" (previous)="previousPage()"
      (next)="nextPage()"></app-pagination>
  </footer>

  <div class="proventos__modal-backdrop" *ngIf="isDeleteModalOpen()" (click)="closeDeleteModal()">
    <div class="proventos__modal" (click)="$event.stopPropagation()">
      <h3>{{ 'proventos.confirmDeleteTitle' | translate }}</h3>
      <p>
        {{ 'proventos.confirmDeleteMessage' | translate }}
        <strong>{{ proventoToDelete()?.codigo }}</strong>?
      </p>

      <div class="proventos__modal-actions">
        <button type="button" class="proventos__modal-btn" [disabled]="isDeleting()" (click)="closeDeleteModal()">
          {{ 'proventos.cancel' | translate }}
        </button>
        <button type="button" class="proventos__modal-btn proventos__modal-btn--danger" [disabled]="isDeleting()"
          (click)="confirmDeleteProvento()">
          {{ isDeleting() ? ('proventos.deleting' | translate) : ('proventos.delete' | translate) }}
        </button>
      </div>
    </div>
  </div>

  <app-add-provento-modal [isOpen]="isCreateModalOpen()" [isSaving]="isCreating()" [tipoOptions]="tipoOptions"
    (closed)="closeCreateModal()" (saved)="confirmCreateProvento($event)">
  </app-add-provento-modal>
</section>
</file>


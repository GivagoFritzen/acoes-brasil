@use '../../colors.scss' as *;

.file-input {
  display: flex;
  flex-direction: column;
  gap: 6px;

  &.is-disabled {
    opacity: 0.7;
  }
}

.file-input__label {
  font-size: 14px;
  color: $color-text-opacity-80;
}

.file-input__desktop {

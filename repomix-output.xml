      border-radius: 8px;
      padding: 6px 10px;
      font-size: 14px;
      background: $color-white;
      min-height: 38px;
    }
  }

  .proventos__row {
    display: grid;
    grid-template-columns: 1fr 1fr 1.2fr 1fr 1fr 1.2fr 1fr 0.7fr;
    align-items: center;
    padding: 12px 8px;
    border-top: 1px solid $color-border;

            });

            it('deve atualizar currentLanguage quando currentLang$ emitir novo valor', () => {
                fixture.detectChanges();
                currentLangSubject.next('en-US');
                expect(component.currentLanguage()).toBe('en-US');
            });
        });

        describe('isDropdownOpen', () => {

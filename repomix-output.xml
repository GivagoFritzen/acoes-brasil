      margin: 0;
    }
  }

  .proventos__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 16px;

    h2 {
      margin: 0;
      font-size: 20px;
      font-weight: 700;
    }
  }

  .proventos__table {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }


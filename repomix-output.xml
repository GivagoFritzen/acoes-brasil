      </p>

      <div class="orders__modal-actions">
        <button type="button" class="orders__modal-btn" [disabled]="isDeleting()" (click)="closeDeleteModal()">
          {{ 'orders.cancel' | translate }}
        </button>
        <button
          type="button"
          class="orders__modal-btn orders__modal-btn--danger"
          [disabled]="isDeleting()"
          (click)="confirmDeleteOrder()"
        >
          {{ isDeleting() ? ('orders.deleting' | translate) : ('orders.delete' | translate) }}
        </button>
      </div>
    </div>
  </div>

  <app-add-order-modal [isOpen]="isCreateModalOpen()" [isSaving]="isCreating()" [operacaoOptions]="operacaoOptions"
    (closed)="closeCreateModal()" (saved)="confirmCreateOrder($event)">
  </app-add-order-modal>
</section>

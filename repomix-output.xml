@use '../../colors.scss' as *;

$size: 16px;

:host {
  display: inline-flex;
  vertical-align: middle;
}

.tooltip-container {
  display: inline-flex;
  align-items: center;
}

.help-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  width: $size;
  height: $size;
  border-radius: 50%;
  background-color: #ebf2ff;
  color: #3b82f6;
  border: 1px solid #d0e1fd;
  font-size: 11px;
  font-weight: bold;
  cursor: pointer;
  user-select: none;
  margin-right: 6px;
  transition: all 0.2s ease-in-out;

  &:hover {
    background-color: #3b82f6;
    color: $color-white;
    border-color: #3b82f6;
  }
}

.tip-content {
  visibility: hidden;
  opacity: 0;
  pointer-events: none;
  position: fixed;
  bottom: 20px;
  left: 16px;
  right: 16px;
  width: auto;
  padding: 16px;
  background-color: #1e293b;
  color: $color-white;
  font-size: 14px;
  font-weight: 400;
  line-height: 1.5;
  border-radius: 12px;
  box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.2);
  z-index: 9999;

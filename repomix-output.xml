  padding: 24px 28px;
  background: $color-white;
  border-radius: 18px;
  box-shadow: 0 18px 40px $color-text-opacity-08;

  ::ng-deep .checkbox-wrapper-2 {
    margin-bottom: 3px;
    margin-top: 8px;

